{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/sda/schemas/fabric-requirements-1.0.json",
  "title": "Dynamic LISP VXLAN Fabric Requirements",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "allocation_domain",
    "metadata",
    "fabric",
    "devices",
    "links",
    "virtual_networks"
  ],
  "properties": {
    "schema_version": {"enum": ["1.0", "1.1", "1.2"]},
    "allocation_domain": {"type": "string", "pattern": "^[A-Za-z0-9_.-]{1,64}$"},
    "deployment_model": {"enum": ["single_site", "distributed_campus"]},
    "site_hierarchy": {
      "type": "array",
      "minItems": 2,
      "maxItems": 8192,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "type"],
        "properties": {
          "id": {"type": "string", "pattern": "^[A-Za-z0-9_.-]{1,64}$"},
          "name": {"type": "string", "minLength": 1, "maxLength": 128},
          "type": {"enum": ["global", "area", "building", "floor"]},
          "parent_id": {"type": "string", "pattern": "^[A-Za-z0-9_.-]{1,64}$"},
          "address": {"type": "string", "maxLength": 512},
          "latitude": {"type": "number", "minimum": -90, "maximum": 90},
          "longitude": {"type": "number", "minimum": -180, "maximum": 180},
          "timezone": {"type": "string", "minLength": 1, "maxLength": 64}
        }
      }
    },
    "fabric_sites": {
      "type": "array",
      "minItems": 1,
      "maxItems": 2048,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id", "name", "hierarchy_node_id", "endpoint_count", "ap_count",
          "site_local_services", "high_availability"
        ],
        "properties": {
          "id": {"type": "string", "pattern": "^[A-Za-z0-9_.-]{1,64}$"},
          "name": {"type": "string", "minLength": 1, "maxLength": 128},
          "hierarchy_node_id": {"type": "string", "pattern": "^[A-Za-z0-9_.-]{1,64}$"},
          "endpoint_count": {"type": "integer", "minimum": 1, "maximum": 1000000},
          "ap_count": {"type": "integer", "minimum": 0, "maximum": 100000},
          "site_local_services": {
            "type": "boolean",
            "description": "Planning signal reserved for the shared-services and survivability topology phase."
          },
          "high_availability": {
            "type": "boolean",
            "description": "Planning signal reserved for per-site role and uplink redundancy enforcement."
          },
          "profile": {
            "enum": ["fabric_in_a_box", "small_site", "medium_site", "large_site"]
          },
          "lisp_multihoming_id": {
            "type": "integer", "minimum": 1, "maximum": 65535,
            "description": "Optional brownfield override shared by redundant border nodes in this site."
          }
        }
      }
    },
    "fabric_zones": {
      "type": "array",
      "maxItems": 8192,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "fabric_site_id", "hierarchy_node_id", "virtual_networks"],
        "properties": {
          "id": {"type": "string", "pattern": "^[A-Za-z0-9_.-]{1,64}$"},
          "fabric_site_id": {"type": "string", "pattern": "^[A-Za-z0-9_.-]{1,64}$"},
          "hierarchy_node_id": {"type": "string", "pattern": "^[A-Za-z0-9_.-]{1,64}$"},
          "virtual_networks": {
            "type": "array",
            "minItems": 1,
            "maxItems": 512,
            "uniqueItems": true,
            "items": {"type": "string", "minLength": 1, "maxLength": 64}
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "environment", "organization", "region"],
      "properties": {
        "name": {"type": "string", "minLength": 1, "maxLength": 128},
        "environment": {"enum": ["lab", "staging", "production"]},
        "organization": {"type": "string", "minLength": 1, "maxLength": 128},
        "region": {"type": "string", "minLength": 1, "maxLength": 64},
        "change_reference": {"type": "string", "maxLength": 128}
      }
    },
    "fabric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "mtu", "control_plane_mode", "lisp_auth_key_ref"],
      "properties": {
        "id": {"type": "string", "pattern": "^[A-Za-z0-9_.-]{1,64}$"},
        "name": {"type": "string", "minLength": 1, "maxLength": 128},
        "mtu": {"type": "integer", "minimum": 1550, "maximum": 9216},
        "control_plane_mode": {"enum": ["classic_lisp", "lisp_bgp_transit", "lisp_pubsub"]},
        "isis_process": {"type": "string", "minLength": 1, "maxLength": 64},
        "isis_area": {"type": "string", "pattern": "^49\\.[0-9]{4}$"},
        "lisp_site_name": {"type": "string", "minLength": 1, "maxLength": 64},
        "lisp_auth_key_ref": {"type": "string", "pattern": "^secret://"},
        "locator_set": {"type": "string", "minLength": 1, "maxLength": 64},
        "lisp_domain_id": {
          "type": "integer", "minimum": 1, "maximum": 4294967295,
          "description": "Optional brownfield override; otherwise allocated from guardrails."
        }
      }
    },
    "devices": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2048,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id", "site", "platform", "software_version", "management_ip", "roles", "credential_ref"
        ],
        "properties": {
          "id": {"type": "string", "pattern": "^[A-Za-z0-9_.-]{1,64}$"},
          "hostname": {"type": "string", "minLength": 1, "maxLength": 63},
          "site": {"type": "string", "minLength": 1, "maxLength": 64},
          "platform": {"type": "string", "minLength": 1, "maxLength": 64},
          "software_version": {"type": "string", "minLength": 1, "maxLength": 64},
          "management_ip": {"type": "string", "format": "ipv4"},
          "dashboard_management_ip": {"type": "string", "format": "ipv4"},
          "roles": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {"enum": ["border", "control_plane", "fabric_edge", "fusion", "underlay"]}
          },
          "credential_ref": {"type": "string", "pattern": "^secret://"}
        }
      }
    },
    "links": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8192,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "endpoints"],
        "properties": {
          "id": {"type": "string", "minLength": 1, "maxLength": 128},
          "pim_sparse_mode": {"type": "boolean"},
          "bfd": {
            "type": "object",
            "additionalProperties": false,
            "required": ["enabled"],
            "properties": {
              "enabled": {"type": "boolean"},
              "interval_ms": {"type": "integer", "minimum": 50, "maximum": 1000},
              "min_rx_ms": {"type": "integer", "minimum": 50, "maximum": 1000},
              "multiplier": {"type": "integer", "minimum": 3, "maximum": 50}
            }
          },
          "endpoints": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["device_id", "interface"],
              "properties": {
                "device_id": {"type": "string", "minLength": 1, "maxLength": 64},
                "interface": {"type": "string", "minLength": 1, "maxLength": 128}
              }
            }
          }
        }
      }
    },
    "virtual_networks": {
      "type": "array",
      "minItems": 1,
      "maxItems": 512,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "vrf", "sites"],
        "properties": {
          "name": {"type": "string", "minLength": 1, "maxLength": 64},
          "vrf": {"type": "string", "minLength": 1, "maxLength": 64},
          "sites": {
            "type": "array",
            "minItems": 1,
            "maxItems": 2048,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["site", "users", "dhcp_helpers"],
              "properties": {
                "site": {"type": "string", "minLength": 1, "maxLength": 64},
                "users": {"type": "integer", "minimum": 1, "maximum": 16777214},
                "headroom_percent": {"type": "integer", "minimum": 0, "maximum": 500},
                "dhcp_helpers": {
                  "type": "array",
                  "minItems": 1,
                  "maxItems": 16,
                  "uniqueItems": true,
                  "items": {"type": "string", "format": "ipv4"}
                }
              }
            }
          }
        }
      }
    },
    "fusion_nodes": {
      "type": "array",
      "minItems": 2,
      "maxItems": 16,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id", "hostname", "platform", "software_version", "management_ip",
          "credential_ref", "bgp_asn"
        ],
        "properties": {
          "id": {"type": "string", "pattern": "^[A-Za-z0-9_.-]{1,64}$"},
          "hostname": {"type": "string", "minLength": 1, "maxLength": 63},
          "platform": {"type": "string", "minLength": 1, "maxLength": 64},
          "software_version": {"type": "string", "minLength": 1, "maxLength": 64},
          "management_ip": {"type": "string", "format": "ipv4"},
          "dashboard_management_ip": {"type": "string", "format": "ipv4"},
          "credential_ref": {"type": "string", "pattern": "^secret://"},
          "bgp_asn": {"type": "integer", "minimum": 1, "maximum": 4294967295}
        }
      }
    },
    "shared_services": {
      "type": "object",
      "additionalProperties": false,
      "required": ["vrf", "default_action", "services", "attachments"],
      "properties": {
        "vrf": {"type": "string", "minLength": 1, "maxLength": 64},
        "default_action": {"const": "deny"},
        "attachments": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "fusion_node_id", "interface"],
            "properties": {
              "id": {"type": "string", "pattern": "^[A-Za-z0-9_.-]{1,64}$"},
              "fusion_node_id": {"type": "string", "minLength": 1, "maxLength": 64},
              "interface": {"type": "string", "minLength": 1, "maxLength": 128}
            }
          }
        },
        "services": {
          "type": "array",
          "minItems": 1,
          "maxItems": 128,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "type", "addresses", "prefixes", "consumer_virtual_networks"],
            "properties": {
              "id": {"type": "string", "pattern": "^[A-Za-z0-9_.-]{1,64}$"},
              "type": {"enum": ["dhcp", "dns", "ntp", "ise", "catalyst_center", "wlc", "other"]},
              "addresses": {
                "type": "array", "minItems": 1, "maxItems": 64, "uniqueItems": true,
                "items": {"type": "string", "format": "ipv4"}
              },
              "prefixes": {
                "type": "array", "minItems": 1, "maxItems": 64, "uniqueItems": true,
                "items": {"type": "string"}
              },
              "consumer_virtual_networks": {
                "type": "array", "minItems": 1, "maxItems": 512, "uniqueItems": true,
                "items": {"type": "string", "minLength": 1, "maxLength": 64}
              }
            }
          }
        }
      }
    },
    "multicast": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "transport", "rp_mode", "asm_virtual_networks", "ssm_virtual_networks"],
      "properties": {
        "enabled": {"type": "boolean"},
        "transport": {"enum": ["native", "head_end_replication"]},
        "rp_mode": {
          "enum": ["anycast", "static", "none"],
          "description": "Underlay/L2-BUM rendezvous-point mode; overlay ASM RPs are declared per VN in overlay_policies."
        },
        "rp_device_ids": {
          "type": "array", "minItems": 1, "maxItems": 4, "uniqueItems": true,
          "items": {"type": "string", "minLength": 1, "maxLength": 64}
        },
        "asm_virtual_networks": {
          "type": "array", "maxItems": 512, "uniqueItems": true,
          "items": {"type": "string", "minLength": 1, "maxLength": 64}
        },
        "ssm_virtual_networks": {
          "type": "array", "maxItems": 512, "uniqueItems": true,
          "items": {"type": "string", "minLength": 1, "maxLength": 64}
        },
        "ssm_range": {"type": "string"},
        "overlay_policies": {
          "type": "array", "maxItems": 512,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["virtual_network", "mode", "group_range"],
            "properties": {
              "virtual_network": {"type": "string", "minLength": 1, "maxLength": 64},
              "mode": {"enum": ["asm", "ssm"]},
              "group_range": {"type": "string"},
              "rp_address": {"type": "string", "format": "ipv4"},
              "rp_prefix": {"type": "string"}
            },
            "allOf": [
              {
                "if": {"properties": {"mode": {"const": "asm"}}, "required": ["mode"]},
                "then": {"required": ["rp_address", "rp_prefix"]},
                "else": {"not": {"anyOf": [{"required": ["rp_address"]}, {"required": ["rp_prefix"]}]}}
              }
            ]
          }
        }
      }
    },
    "policy_plane": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "security_groups", "contracts"],
      "properties": {
        "mode": {"enum": ["none", "ise", "sxp", "hybrid"]},
        "contract_version": {"const": "1.0"},
        "default_action": {"const": "deny"},
        "ise": {
          "type": "object",
          "additionalProperties": false,
          "required": ["credential_ref", "nodes"],
          "properties": {
            "credential_ref": {"type": "string", "pattern": "^secret://"},
            "ca_bundle_ref": {"type": "string", "pattern": "^secret://"},
            "write_node_id": {"type": "string", "pattern": "^[A-Za-z0-9_.-]{1,64}$"},
            "nodes": {
              "type": "array", "minItems": 1, "maxItems": 32,
              "items": {
                "type": "object", "additionalProperties": false,
                "required": ["id", "address", "roles"],
                "properties": {
                  "id": {"type": "string", "pattern": "^[A-Za-z0-9_.-]{1,64}$"},
                  "address": {"type": "string", "format": "ipv4"},
                  "api_base_url": {"type": "string", "pattern": "^https://[A-Za-z0-9.-]+(?::(?:[1-9][0-9]{0,3}|[1-5][0-9]{4}|6[0-4][0-9]{3}|65[0-4][0-9]{2}|655[0-2][0-9]|6553[0-5]))?$"},
                  "roles": {
                    "type": "array", "minItems": 1, "uniqueItems": true,
                    "items": {"enum": ["pan", "psn", "pxgrid"]}
                  }
                }
              }
            }
          }
        },
        "sxp": {
          "type": "object",
          "additionalProperties": false,
          "required": ["connections"],
          "properties": {
            "connections": {
              "type": "array", "minItems": 1, "maxItems": 1024,
              "items": {
                "type": "object", "additionalProperties": false,
                "required": ["id", "speaker_id", "listener_ip", "password_ref"],
                "properties": {
                  "id": {"type": "string", "pattern": "^[A-Za-z0-9_.-]{1,64}$"},
                  "speaker_id": {"type": "string", "minLength": 1, "maxLength": 64},
                  "transport_vrf": {"type": "string", "minLength": 1, "maxLength": 64},
                  "listener_ip": {"type": "string", "format": "ipv4"},
                  "listener_prefix": {"type": "string"},
                  "password_ref": {"type": "string", "pattern": "^secret://"}
                }
              }
            }
          }
        },
        "security_groups": {
          "type": "array", "minItems": 1, "maxItems": 4096,
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["name"],
            "properties": {
              "name": {"type": "string", "minLength": 1, "maxLength": 64},
              "tag": {"type": "integer", "minimum": 2, "maximum": 65519}
            }
          }
        },
        "contracts": {
          "type": "array", "maxItems": 16384,
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["source", "destination", "action", "protocol"],
            "properties": {
              "source": {"type": "string", "minLength": 1, "maxLength": 64},
              "destination": {"type": "string", "minLength": 1, "maxLength": 64},
              "action": {"enum": ["permit", "deny"]},
              "protocol": {"enum": ["ip", "tcp", "udp", "icmp"]}
            }
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {"contract_version": {"const": "1.0"}},
            "required": ["contract_version"]
          },
          "then": {
            "required": ["default_action"],
            "properties": {
              "ise": {
                "required": ["credential_ref", "write_node_id", "nodes"],
                "properties": {
                  "nodes": {
                    "items": {"required": ["id", "address", "api_base_url", "roles"]}
                  }
                }
              },
              "sxp": {
                "properties": {
                  "connections": {
                    "items": {
                      "required": ["id", "speaker_id", "transport_vrf", "listener_ip", "listener_prefix", "password_ref"]
                    }
                  }
                }
              }
            }
          }
        },
        {
          "if": {"properties": {"mode": {"const": "ise"}}, "required": ["mode"]},
          "then": {"required": ["ise"], "not": {"required": ["sxp"]}}
        },
        {
          "if": {"properties": {"mode": {"const": "sxp"}}, "required": ["mode"]},
          "then": {"required": ["sxp"], "not": {"required": ["ise"]}}
        },
        {
          "if": {"properties": {"mode": {"const": "hybrid"}}, "required": ["mode"]},
          "then": {"required": ["ise", "sxp"]}
        },
        {
          "if": {"properties": {"mode": {"const": "none"}}, "required": ["mode"]},
          "then": {
            "not": {"anyOf": [{"required": ["ise"]}, {"required": ["sxp"]}]}
          }
        }
      ]
    },
    "border_handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "mode"],
      "properties": {
        "enabled": {"type": "boolean"},
        "mode": {"enum": ["bgp", "isolated"]},
        "remote_as": {"type": "integer", "minimum": 1, "maximum": 4294967295},
        "adjacencies": {
          "type": "array",
          "minItems": 1,
          "maxItems": 256,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["border_device_id", "fusion_node_id", "border_interface", "fusion_interface"],
            "properties": {
              "border_device_id": {"type": "string", "minLength": 1, "maxLength": 64},
              "fusion_node_id": {"type": "string", "minLength": 1, "maxLength": 64},
              "border_interface": {"type": "string", "minLength": 1, "maxLength": 128},
              "fusion_interface": {"type": "string", "minLength": 1, "maxLength": 128},
              "virtual_networks": {
                "type": "array", "minItems": 1, "maxItems": 512, "uniqueItems": true,
                "items": {"type": "string", "minLength": 1, "maxLength": 64}
              }
            }
          }
        },
        "peers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["device_id", "vrf"],
            "properties": {
              "device_id": {"type": "string", "minLength": 1},
              "vrf": {"type": "string", "minLength": 1},
              "interface": {"type": "string", "minLength": 1}
            }
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {"schema_version": {"const": "1.2"}},
        "required": ["schema_version"]
      },
      "then": {
        "required": [
          "deployment_model", "site_hierarchy", "fabric_sites", "fusion_nodes",
          "shared_services", "multicast", "policy_plane", "border_handoff"
        ],
        "properties": {
          "multicast": {
            "required": [
              "enabled", "transport", "rp_mode", "asm_virtual_networks",
              "ssm_virtual_networks", "overlay_policies"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {"schema_version": {"const": "1.1"}},
        "required": ["schema_version"]
      },
      "then": {
        "required": ["deployment_model", "site_hierarchy", "fabric_sites"],
        "not": {
          "anyOf": [
            {"required": ["fusion_nodes"]},
            {"required": ["shared_services"]},
            {"required": ["policy_plane"]}
          ]
        }
      }
    },
    {
      "if": {
        "properties": {"schema_version": {"const": "1.0"}},
        "required": ["schema_version"]
      },
      "then": {
        "not": {
          "anyOf": [
            {"required": ["deployment_model"]},
            {"required": ["site_hierarchy"]},
            {"required": ["fabric_sites"]},
            {"required": ["fabric_zones"]},
            {"required": ["fusion_nodes"]},
            {"required": ["shared_services"]},
            {"required": ["policy_plane"]}
          ]
        }
      }
    }
  ]
}
