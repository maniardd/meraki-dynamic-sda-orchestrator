# Meraki API access. Never commit real values.
# Official Meraki SDK/API environment variable name.
MERAKI_DASHBOARD_API_KEY=
# Legacy local scripts also accept MERAKI_API_KEY, but do not set both.
# MERAKI_API_KEY=
MERAKI_ORG_ID=
MERAKI_NETWORK_ID=
MERAKI_NETWORK_NAME=SDA-LAB
MERAKI_BASE_URL=https://api.meraki.com/api/v1

# Development-only API bearer token. Production uses separated service
# identities supplied by the approved secret manager.
ORCHESTRATOR_API_TOKEN=
ORCHESTRATOR_TOKEN_IDENTITIES={}
ORCHESTRATOR_HOST=127.0.0.1
ORCHESTRATOR_PORT=8080
ORCHESTRATOR_DATABASE_URL=
ORCHESTRATOR_EXECUTION_ENABLED=false
ORCHESTRATOR_WORKER_ENABLED=false

# Production workers resolve device credential_ref values at execution time.
# Never place device usernames or passwords in this file.
ORCHESTRATOR_SECRET_PROVIDER=
# ORCHESTRATOR_SECRET_FILE=/home/REPLACE_USER/.config/sda-orchestrator/secrets.json
# VAULT_ADDR=https://vault.example.invalid
# VAULT_TOKEN_FILE=/home/REPLACE_USER/.config/sda-orchestrator/vault-token
# VAULT_CACERT=/etc/ssl/certs/approved-vault-ca.pem
