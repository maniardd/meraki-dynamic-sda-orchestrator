# Installed as ~/.config/sda-orchestrator/worker.env with mode 0600.
ORCHESTRATOR_DATABASE_URL=postgresql://sda_orchestrator@127.0.0.1/sda_orchestrator
PGPASSFILE=/home/REPLACE_USER/.config/sda-orchestrator/pgpass
ORCHESTRATOR_EXECUTION_ENABLED=false
ORCHESTRATOR_WORKER_ENABLED=false
ORCHESTRATOR_WORKER_IDENTITY=sda-worker
ORCHESTRATOR_SECRET_PROVIDER=vault_kv
VAULT_ADDR=https://vault.example.invalid
VAULT_TOKEN_FILE=/home/REPLACE_USER/.config/sda-orchestrator/vault-token
VAULT_CACERT=/etc/ssl/certs/approved-vault-ca.pem
VAULT_TIMEOUT_SECONDS=10
